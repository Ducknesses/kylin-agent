# ============================================================
# DeepSeek Agent 后端环境变量模板
# 使用方法: cp .env.example .env 然后填写实际值
# .env 已被 .gitignore 排除，不会提交到 Git
# ============================================================

# ---------- DeepSeek API ----------
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---------- MCP Server ----------
MCP_MODE=mock
MCP_SERVER_URL=http://192.168.56.101:8001
# MCP Server Bearer Token（生产环境必须配置）
MCP_AUTH_TOKEN=change-me-in-production

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- SQLite ----------
SQLITE_DB=./data/audit.db

# ---------- FastAPI ----------
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ---------- Token 认证（空=不启用） ----------
API_TOKEN=

# ---------- 运行时 ----------
COMMAND_TIMEOUT=30
MAX_INPUT_LENGTH=2000

# ---------- Mock/Real 模式切换 ----------
# true  → 走真实 DeepSeek + MCP 链路（需配置 DEEPSEEK_API_KEY + MCP_SERVER_URL）
# false → 走 Mock 编排器（关键词匹配，仅供前端联调，默认值）
USE_REAL_LLM=false

# ---------- 日志等级 ----------
LOG_LEVEL=INFO
