# 后端环境变量模板 —— 复制为 .env 后修改
# 生产环境请通过系统环境变量注入，不要将 .env 提交到 Git

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# MCP 执行器 C
MCP_MODE=mock
MCP_SERVER_URL=http://192.168.56.101:8001
MCP_AUTH_TOKEN=change-me-in-production

# Redis
REDIS_URL=redis://localhost:6379/0

# SQLite 审计数据库路径
SQLITE_DB=./data/audit.db

# 运行时参数
COMMAND_TIMEOUT=30
MAX_INPUT_LENGTH=2000

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
